---
interface Props {
  name: string;
  class?: string;
}
const { name, class: cls = "w-6 h-6" } = Astro.props;
---

{name === "axe" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M14 4l6 6-3 3-6-6 3-3z"/>
    <path d="M11 7l-7 7v6h6l7-7"/>
  </svg>
)}

{name === "scissors" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="6" cy="6" r="3"/>
    <circle cx="6" cy="18" r="3"/>
    <line x1="20" y1="4" x2="8.12" y2="15.88"/>
    <line x1="14.47" y1="14.48" x2="20" y2="20"/>
    <line x1="8.12" y1="8.12" x2="12" y2="12"/>
  </svg>
)}

{name === "leaf" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M11 20A7 7 0 0 1 4 13c0-5 5-9 16-9 0 7-4 16-9 16z"/>
    <path d="M4 13c4 0 7 3 7 7"/>
  </svg>
)}

{name === "grinder" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="14" r="6"/>
    <circle cx="12" cy="14" r="2"/>
    <path d="M12 8V4M8 4h8"/>
  </svg>
)}

{name === "truck" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="1" y="6" width="14" height="11"/>
    <path d="M15 9h5l3 4v4h-8"/>
    <circle cx="6" cy="20" r="2"/>
    <circle cx="18" cy="20" r="2"/>
  </svg>
)}

{name === "magnifier" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
    <path d="M8 11h6M11 8v6"/>
  </svg>
)}

{name === "lightning" && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
  </svg>
)}
