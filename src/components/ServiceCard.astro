---
import { Picture } from "astro:assets";
import ServiceIcon from "./ServiceIcon.astro";

interface Props {
  title: string;
  summary: string;
  icon: string;
  href: string;
  slug?: string;
  liveIndicator?: boolean;
}

const { title, summary, icon, href, slug, liveIndicator = false } = Astro.props;

const serviceImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/services/*.jpg",
  { eager: true },
);
const img = slug
  ? serviceImages[`../assets/images/services/${slug}.jpg`]?.default
  : undefined;
---

<a
  href={href}
  class="group flex flex-col bg-white border border-arbor-800/10 rounded-2xl overflow-hidden hover:border-arbor-800/30 hover:shadow-xl transition shadow-sm"
>
  {img && (
    <div class="relative aspect-[16/10] overflow-hidden bg-arbor-100">
      <Picture
        src={img}
        alt=""
        widths={[320, 480, 640]}
        sizes="(min-width: 1024px) 400px, (min-width: 640px) 50vw, 100vw"
        formats={["avif", "webp"]}
        loading="lazy"
        pictureAttributes={{ class: "absolute inset-0 w-full h-full" }}
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
      <div class="absolute bottom-3 left-3 w-10 h-10 rounded-full bg-cream/95 text-arbor-800 flex items-center justify-center shadow-md">
        <ServiceIcon name={icon} class="w-5 h-5" />
      </div>
    </div>
  )}

  <div class="flex flex-col p-6 flex-1">
    {!img && (
      <div class="w-12 h-12 rounded-full bg-arbor-800/10 text-arbor-800 flex items-center justify-center mb-4 group-hover:bg-arbor-800 group-hover:text-cream transition">
        <ServiceIcon name={icon} class="w-6 h-6" />
      </div>
    )}
    <h3 class="text-lg font-semibold text-arbor-900 mb-2">{title}</h3>
    <p class="text-sm text-arbor-900/70 leading-relaxed flex-1">
      {liveIndicator && (
        <span class="relative inline-flex w-2 h-2 mr-2 align-middle" aria-label="Live 24-hour line">
          <span class="absolute inset-0 rounded-full bg-green-500 opacity-75 animate-ping"></span>
          <span class="relative inline-block w-2 h-2 rounded-full bg-green-500 shadow-[0_0_6px_2px_rgba(34,197,94,0.7)]"></span>
        </span>
      )}
      {summary}
    </p>
    <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-arbor-800 group-hover:gap-2 transition-all">
      Learn more
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </span>
  </div>
</a>
