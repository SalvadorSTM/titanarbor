---
import { Image } from "astro:assets";
import { site, services, serviceAreas, telHref, mailHref } from "../lib/site";
import logoImage from "../assets/logo.png";
const year = new Date().getFullYear();
---

<footer class="bg-arbor-900 text-arbor-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid gap-10 md:grid-cols-2 lg:grid-cols-4">

    <div>
      <div class="flex items-center gap-3 mb-4">
        <Image
          src={logoImage}
          alt=""
          widths={[48, 96]}
          sizes="48px"
          class="w-12 h-12 rounded-full ring-2 ring-arbor-100/20"
          loading="lazy"
        />
        <div class="font-bold text-cream text-lg">
          {site.shortName}
          <span class="block text-xs font-normal text-arbor-100/80 uppercase tracking-wider">Solutions</span>
        </div>
      </div>
      <p class="text-sm text-arbor-100/80 leading-relaxed">
        Locally owned tree care, based in {site.legal.city}, {site.legal.stateAbbr}.
        Licensed, insured, and on call when you need us.
      </p>
    </div>

    <div>
      <h3 class="text-cream font-semibold uppercase tracking-wider text-sm mb-4">Services</h3>
      <ul class="space-y-2 text-sm">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug}/`} class="text-arbor-100/80 hover:text-cream transition">
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-cream font-semibold uppercase tracking-wider text-sm mb-4">Service Areas</h3>
      <ul class="grid grid-cols-2 gap-x-3 gap-y-1 text-sm text-arbor-100/80">
        {serviceAreas.slice(0, 8).map((a) => <li>{a.name}</li>)}
      </ul>
      <a href="/service-areas/" class="inline-block mt-3 text-sm text-cream hover:underline underline-offset-4">
        See all areas →
      </a>
    </div>

    <div>
      <h3 class="text-cream font-semibold uppercase tracking-wider text-sm mb-4">Contact</h3>
      <ul class="space-y-3 text-sm">
        <li>
          <a href={telHref(site.phonePrimary)} class="text-cream font-semibold text-base hover:underline underline-offset-4">
            {site.phonePrimary}
          </a>
          <div class="text-arbor-100/80 text-xs">Primary line</div>
        </li>
        <li>
          <a href={telHref(site.phoneBackup)} class="text-arbor-100/80 hover:text-cream">
            {site.phoneBackup}
          </a>
          <div class="text-arbor-100/80 text-xs">Backup line</div>
        </li>
        <li>
          <a href={mailHref(site.email)} class="text-arbor-100/80 hover:text-cream break-all">
            {site.email}
          </a>
        </li>
        <li class="pt-3 border-t border-arbor-100/10 mt-2">
          <p class="text-cream text-xs uppercase tracking-wider font-semibold mb-2">Hours</p>
          <ul class="space-y-1">
            {site.hoursDetailed.map((h) => {
              const isClosed = h.time === "Closed";
              return (
                <li class="flex items-baseline justify-between gap-3 text-xs">
                  <span class={isClosed ? "text-arbor-100/60" : "text-arbor-100/90"}>{h.day}</span>
                  <span class={isClosed ? "text-red-300 font-bold uppercase tracking-wider" : "text-arbor-100/70"}>{h.time}</span>
                </li>
              );
            })}
          </ul>
          <p class="text-cream text-xs font-semibold mt-2 leading-relaxed">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-cream animate-pulse mr-1.5 align-middle"></span>
            24-hour emergency line
          </p>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-arbor-100/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-arbor-100/80">
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <nav class="flex gap-4" aria-label="Legal">
        <a href="/privacy/" class="hover:text-cream">Privacy</a>
        <a href="/terms/" class="hover:text-cream">Terms</a>
        <a href="/faq/" class="hover:text-cream">FAQ</a>
      </nav>
      <p>{site.legal.state} {site.legal.entityType} · Licensed &amp; insured</p>
    </div>
  </div>
</footer>
