---
import "../styles/global.css";
import { site, services, serviceAreas, telHref } from "../lib/site";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileCallBar from "../components/MobileCallBar.astro";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  pathname = Astro.url.pathname,
  noindex = !site.published,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.shortName}` : `${site.name} — ${site.tagline}`;
const canonical = new URL(pathname, site.url).toString();
const ogImage = new URL("/logo.png", site.url).toString();

const telE164 = (n: string) => `+1${n.replace(/\D/g, "")}`;

const jsonLd = site.published
  ? {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "additionalType": "https://schema.org/HomeAndConstructionBusiness",
      "@id": `${site.url}/#business`,
      name: site.name,
      image: ogImage,
      logo: ogImage,
      url: site.url,
      telephone: telE164(site.phonePrimary),
      email: site.email,
      priceRange: "$$",
      address: {
        "@type": "PostalAddress",
        addressRegion: site.legal.state,
        addressCountry: "US",
      },
      areaServed: serviceAreas.map((a) => ({ "@type": "City", name: a.name })),
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          opens: "07:00",
          closes: "19:00",
        },
      ],
      contactPoint: [
        {
          "@type": "ContactPoint",
          telephone: telE164(site.phonePrimary),
          contactType: "customer service",
          areaServed: "US-GA",
          availableLanguage: ["English", "Spanish"],
        },
        {
          "@type": "ContactPoint",
          telephone: telE164(site.phoneBackup),
          contactType: "customer service",
          areaServed: "US-GA",
        },
      ],
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Tree Care Services",
        itemListElement: services.map((s) => ({
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: s.title,
            description: s.summary,
            url: `${site.url}/services/${s.slug}/`,
          },
        })),
      },
    }
  : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#1f4d2b" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-cream text-arbor-900 antialiased min-h-screen flex flex-col pb-14 lg:pb-0">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-arbor-800 focus:text-cream focus:rounded">
      Skip to main content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <MobileCallBar />
  </body>
</html>
