---
import { Image } from "astro:assets";
import logoImage from "../assets/images/partners/red-roofing-logo.jpg";
import portraitImage from "../assets/images/partners/jeremy-farrell.jpg";

const contact = {
  name: "Jeremy Farrell",
  role: "Project Manager",
  phone: "404-556-3936",
  email: "jeremyf@redroofing.org",
  site: "https://redroofing.org/",
};

const telHref = `tel:${contact.phone.replace(/\D/g, "")}`;
const mailHref = `mailto:${contact.email}`;
---

<section class="bg-cream py-12 sm:py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <p class="text-sm uppercase tracking-widest text-arbor-800 mb-3 font-semibold text-center">Our roofing partner</p>
    <h2 class="text-2xl sm:text-3xl font-bold text-arbor-900 tracking-tight text-center mb-8">
      Tree through a roof? They handle the repair.
    </h2>

    <div class="bg-white border border-arbor-800/15 rounded-2xl overflow-hidden shadow-sm grid sm:grid-cols-5">
      <div class="sm:col-span-2 relative aspect-square sm:aspect-auto bg-arbor-100">
        <Image
          src={portraitImage}
          alt={`${contact.name}, ${contact.role} at Red Roofing & Gutters`}
          widths={[320, 480, 640]}
          sizes="(min-width: 640px) 320px, 100vw"
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>

      <div class="sm:col-span-3 p-6 sm:p-8 flex flex-col">
        <div class="bg-white rounded-xl p-4 mb-5 inline-flex items-center justify-center self-start">
          <Image
            src={logoImage}
            alt="Red Roofing & Gutters"
            widths={[200, 300, 400]}
            sizes="(min-width: 640px) 200px, 50vw"
            loading="lazy"
            class="h-16 sm:h-20 w-auto object-contain"
          />
        </div>

        <p class="text-arbor-900/80 leading-relaxed mb-5">
          When a tree comes through a roof, you need two crews — tree people and roof people.
          <strong class="text-arbor-900">Red Roofing &amp; Gutters</strong> is our official roofing partner,
          covering metro Atlanta out of Madison, GA. They specialize in homeowners' insurance claims, so the
          paperwork is handled by people who do it every day. Call us first — we'll loop them in.
        </p>

        <div class="border-t border-arbor-800/10 pt-5 mt-auto">
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-2">Direct line</p>
          <p class="font-semibold text-arbor-900">{contact.name}</p>
          <p class="text-sm text-arbor-900/70 mb-3">{contact.role} · Red Roofing &amp; Gutters</p>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 text-sm">
            <a href={telHref} class="inline-flex items-center gap-2 text-arbor-800 hover:text-arbor-900 font-semibold">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
              </svg>
              {contact.phone}
            </a>
            <a href={mailHref} class="inline-flex items-center gap-2 text-arbor-800 hover:text-arbor-900 font-semibold break-all">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              {contact.email}
            </a>
            <a href={contact.site} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-arbor-800 hover:text-arbor-900 font-semibold">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              redroofing.org
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
