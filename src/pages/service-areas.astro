---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CityCard from "../components/CityCard.astro";
import { serviceAreas, site } from "../lib/site";
---

<BaseLayout
  title="Service Areas"
  description="Titan Arbor Solutions serves metro Atlanta — Atlanta, Decatur, Stone Mountain, Sandy Springs, Roswell, Marietta, Dunwoody, Brookhaven, Tucker, Avondale Estates, Smyrna, Chamblee, and surrounding areas."
>

  <section class="relative text-cream overflow-hidden">
    <img
      src="/images/service-areas.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-arbor-900/85 via-arbor-800/75 to-arbor-900/90" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
      <p class="text-sm uppercase tracking-widest text-arbor-100 mb-3">Service Areas</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight drop-shadow-lg">
        Where we work
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-arbor-100 max-w-2xl">
        Based in {site.legal.state}. We cover the city of Atlanta and the surrounding metro — north, south, east, and west — and we go where the work is.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-arbor-900 mb-8 text-center">Cities we regularly serve</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceAreas.map((area) => (
          <CityCard name={area.name} slug={area.slug} blurb={area.blurb} />
        ))}
      </div>

      <div class="mt-12 bg-arbor-100/40 border border-arbor-800/15 rounded-2xl p-6 sm:p-8 text-center">
        <h3 class="text-xl sm:text-2xl font-bold text-arbor-900 mb-2">Don't see your area?</h3>
        <p class="text-arbor-900/80 max-w-2xl mx-auto">
          The list above is what we cover routinely, but we travel for the right job. Call us with your address and we'll tell you straight up whether it's a fit. No charge for the conversation.
        </p>
      </div>
    </div>
  </section>

  <CTA variant="compact" heading="Call us with your address" body="We'll tell you whether we cover your area and book a free quote." />
</BaseLayout>
