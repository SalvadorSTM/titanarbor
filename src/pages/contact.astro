---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, telHref, mailHref } from "../lib/site";
import contactHero from "../assets/images/contact.jpg";

const mapUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${site.legal.streetAddress}, ${site.legal.city}, ${site.legal.stateAbbr} ${site.legal.postalCode}`)}`;
---

<BaseLayout
  title="Contact"
  description="Contact Titan Arbor Solutions. Call 478-266-8020, email diego@titanarbor.com. 24-hour emergency tree service across metro Atlanta."
>

  <section class="relative text-cream overflow-hidden">
    <Image
      src={contactHero}
      alt=""
      widths={[640, 1024, 1600]}
      sizes="100vw"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-arbor-900/85 via-arbor-800/80 to-arbor-900/90" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20 sm:py-24">
      <p class="text-sm uppercase tracking-widest text-arbor-100 mb-3">Contact</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight drop-shadow-lg">
        Get a quote, or just ask.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-arbor-100 max-w-2xl mx-auto">
        Request a free quote online, or call any time. Diego picks up; if he can't, leave a voicemail and you'll hear back the same day.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-16 px-4 sm:px-6 lg:px-8 bg-arbor-100/30">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-6 lg:gap-8 items-start">

      <!-- Left: contact info panel -->
      <aside class="lg:col-span-2 bg-white rounded-2xl p-6 sm:p-8 border border-arbor-800/15 shadow-sm space-y-6">

        <div>
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-1">Primary line</p>
          <a href={telHref(site.phonePrimary)} class="block text-3xl sm:text-4xl font-bold text-arbor-900 hover:text-arbor-700 transition leading-tight">
            {site.phonePrimary}
          </a>
          <p class="text-xs text-arbor-900/60 mt-1">Diego answers. Tap to call.</p>
        </div>

        <div>
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-1">Backup line</p>
          <a href={telHref(site.phoneBackup)} class="block text-xl sm:text-2xl font-bold text-arbor-900 hover:text-arbor-700 transition">
            {site.phoneBackup}
          </a>
        </div>

        <div>
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-1">Email</p>
          <a href={mailHref(site.email, "Tree care inquiry")} class="block text-base sm:text-lg font-semibold text-arbor-900 hover:text-arbor-700 transition break-all">
            {site.email}
          </a>
        </div>

        <div class="border-t border-arbor-800/10 pt-6">
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-3">Hours</p>
          <ul class="space-y-1.5">
            {site.hoursDetailed.map((h) => {
              const isClosed = h.time === "Closed";
              return (
                <li class="flex items-baseline justify-between gap-3 text-sm">
                  <span class={isClosed ? "text-arbor-900/60" : "text-arbor-900 font-medium"}>{h.day}</span>
                  <span class={isClosed ? "text-red-700 font-bold uppercase text-xs tracking-wider" : "text-arbor-900/80"}>{h.time}</span>
                </li>
              );
            })}
          </ul>
          <p class="text-arbor-800 font-semibold text-xs mt-4 leading-relaxed">
            <span class="inline-block w-2 h-2 rounded-full bg-arbor-800 animate-pulse mr-1.5 align-middle"></span>
            24-hour emergency line for storm damage
          </p>
        </div>

        <div class="border-t border-arbor-800/10 pt-6">
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-2">Address</p>
          <address class="not-italic text-sm text-arbor-900 leading-relaxed">
            {site.legal.streetAddress}<br/>
            {site.legal.city}, {site.legal.stateAbbr} {site.legal.postalCode}
          </address>
          <a
            href={mapUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1 mt-2 text-arbor-800 font-semibold text-xs hover:gap-2 transition-all"
          >
            Open in Google Maps
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>

        <div class="border-t border-arbor-800/10 pt-6">
          <p class="text-xs uppercase tracking-widest text-arbor-800 font-semibold mb-2">Service area</p>
          <p class="text-sm text-arbor-900/80 leading-relaxed">
            Metro Atlanta &mdash; Fulton, DeKalb, and Cobb counties.
          </p>
          <a href="/service-areas/" class="inline-flex items-center gap-1 mt-2 text-arbor-800 font-semibold text-xs hover:gap-2 transition-all">
            See all 13 cities we serve
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </aside>

      <!-- Right: Jobber form embed -->
      <div class="lg:col-span-3 bg-white rounded-2xl p-4 sm:p-6 md:p-8 border border-arbor-800/15 shadow-sm">
        <div id="7da855e7-9b31-44ee-bec8-2e8fbe6d7d51-4723911"></div>
        <link rel="stylesheet" href="https://d3ey4dbjkt2f6s.cloudfront.net/assets/external/work_request_embed.css" media="screen" />
        <script
          is:inline
          src="https://d3ey4dbjkt2f6s.cloudfront.net/assets/static_link/work_request_embed_snippet.js"
          clienthub_id="7da855e7-9b31-44ee-bec8-2e8fbe6d7d51-4723911"
          form_url="https://clienthub.getjobber.com/client_hubs/7da855e7-9b31-44ee-bec8-2e8fbe6d7d51/public/work_request/embedded_work_request_form?form_id=4723911"
        ></script>

        <p class="text-center text-xs text-arbor-900/60 mt-6 pt-6 border-t border-arbor-800/10">
          Having trouble with the form?
          <a href={site.quoteUrl} target="_blank" rel="noopener" class="text-arbor-800 font-semibold underline underline-offset-4 hover:text-arbor-700">
            Open it in a new window
          </a>
          or call <a href={telHref(site.phonePrimary)} class="text-arbor-800 font-semibold underline underline-offset-4 hover:text-arbor-700">{site.phonePrimary}</a>.
        </p>
      </div>

    </div>
  </section>
</BaseLayout>
