---
interface Props {
  name: string;
  slug: string;
  blurb: string;
}

const { name, slug, blurb } = Astro.props;
---

<article class="bg-white border border-arbor-800/10 rounded-2xl overflow-hidden shadow-sm">
  <div class="relative aspect-[16/10] overflow-hidden bg-arbor-100">
    <img
      src={`/images/cities/${slug}.jpg`}
      alt=""
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-arbor-900/60 via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute bottom-3 left-4 right-4 text-cream">
      <h3 class="text-lg sm:text-xl font-bold drop-shadow-lg flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {name}
      </h3>
    </div>
  </div>
  <p class="px-5 py-4 text-sm text-arbor-900/70 leading-relaxed">{blurb}</p>
</article>
