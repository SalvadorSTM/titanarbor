---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTA from "../components/CTA.astro";
import { site, serviceAreas, telHref } from "../lib/site";
import heroImage from "../assets/images/hero.jpg";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout>
  <section class="relative text-cream overflow-hidden min-h-[70vh] flex items-center">
    <Picture
      src={heroImage}
      alt=""
      widths={[480, 768, 1280, 1600]}
      sizes="100vw"
      formats={["avif", "webp"]}
      pictureAttributes={{ class: "absolute inset-0 w-full h-full" }}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-arbor-900/85 via-arbor-800/75 to-arbor-900/90" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-32 w-full">
      <div class="max-w-3xl">
        <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cream/15 backdrop-blur text-cream text-xs uppercase tracking-widest font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          24-hour emergency response
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight leading-[1.05] drop-shadow-lg">
          Tree care done right,<br/>
          <span class="text-arbor-100">by people who live here.</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-arbor-100 max-w-2xl leading-relaxed">
          Removal, trimming, pruning, stump grinding, and 24-hour storm response across metro Atlanta. Locally owned, licensed, insured. Free quotes.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href={telHref(site.phonePrimary)}
            class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-cream text-arbor-900 rounded-full font-semibold hover:bg-white transition shadow-xl"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call {site.phonePrimary}
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-cream text-arbor-900 rounded-full font-semibold hover:bg-white transition shadow-xl"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="9" y1="13" x2="15" y2="13"/>
              <line x1="9" y1="17" x2="15" y2="17"/>
            </svg>
            Get a FREE quote
          </a>
          <a
            href="/#services"
            class="inline-flex items-center justify-center gap-2 px-7 py-4 border-2 border-cream/40 text-cream rounded-full font-semibold hover:bg-cream/10 backdrop-blur transition"
          >
            See our services
          </a>
        </div>

        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-cream/90 text-sm font-medium">
          {[
            "Licensed",
            "Insured",
            "24-Hour Emergency",
            "Free Quotes",
          ].map((badge) => (
            <li class="inline-flex items-center gap-2">
              <svg class="w-4 h-4 text-cream shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {badge}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section id="services" class="scroll-mt-20 py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-cream">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-3 font-semibold">What we do</p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-arbor-900 tracking-tight">
          Seven services. One honest crew.
        </h2>
        <p class="mt-4 text-lg text-arbor-900/70">
          From routine maintenance to storm emergencies, we handle the full lifecycle of every tree on your property.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <ServiceCard
            title={s.data.title}
            summary={s.data.summary}
            icon={s.data.icon}
            href={`/services/${s.id}/`}
            slug={s.id}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-3 font-semibold">Why Titan Arbor</p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-arbor-900 tracking-tight">
          Local. Honest. On call.
        </h2>
        <p class="mt-6 text-lg text-arbor-900/80 leading-relaxed">
          Titan Arbor Solutions is a locally owned and operated team — our lead arborist is on every job, with five years in the trade and currently working toward ISA Certified Arborist credentials.
        </p>
        <p class="mt-4 text-lg text-arbor-900/80 leading-relaxed">
          You'll never get bait-and-switch pricing or a salesperson who never sets foot near your tree. The same person who quotes the job runs the job.
        </p>
        <div class="mt-8 grid sm:grid-cols-2 gap-4">
          {[
            { title: "Licensed", body: "Georgia LLC, registered with the GA Department of Revenue and Department of Labor." },
            { title: "Fully insured", body: "General liability + workers' comp on every job. Certificate available on request." },
            { title: "Free quotes", body: "Honest assessments. If a tree doesn't need work, we'll tell you." },
            { title: "24-hour storm line", body: "When the wind takes one down, we answer at any hour." },
          ].map((item) => (
            <div class="border-l-2 border-arbor-800 pl-4">
              <p class="font-semibold text-arbor-900">{item.title}</p>
              <p class="text-sm text-arbor-900/70 mt-1">{item.body}</p>
            </div>
          ))}
        </div>
        <a href="/about/" class="inline-flex items-center gap-1 mt-8 text-arbor-800 font-semibold hover:gap-2 transition-all">
          More about our team
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <div class="bg-arbor-800 rounded-3xl p-8 sm:p-10 text-cream">
        <p class="text-sm uppercase tracking-widest text-arbor-100 mb-3 font-semibold">Service areas</p>
        <h3 class="text-2xl sm:text-3xl font-bold mb-6">Across metro Atlanta</h3>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2 text-arbor-100">
          {serviceAreas.map((area) => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cream/80 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {area.name}
            </li>
          ))}
        </ul>
        <a href="/service-areas/" class="inline-flex items-center gap-1 mt-6 text-cream font-semibold hover:gap-2 transition-all">
          Not seeing your area? Ask us
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
