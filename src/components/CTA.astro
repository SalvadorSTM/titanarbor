---
import { site, telHref, mailHref } from "../lib/site";

interface Props {
  heading?: string;
  body?: string;
  variant?: "default" | "compact";
}

const {
  heading = "Need a tree handled?",
  body = "Call any time — Diego picks up. Free quotes, 24-hour emergency response.",
  variant = "default",
} = Astro.props;

const isCompact = variant === "compact";
---

<section class:list={[
  "bg-arbor-800 text-cream",
  isCompact ? "py-10" : "py-16 sm:py-20",
]}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class:list={[
      "font-bold tracking-tight text-cream",
      isCompact ? "text-2xl sm:text-3xl" : "text-3xl sm:text-4xl md:text-5xl",
    ]}>
      {heading}
    </h2>
    <p class:list={[
      "text-arbor-100 mt-3 max-w-2xl mx-auto",
      isCompact ? "text-base" : "text-lg sm:text-xl",
    ]}>
      {body}
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={telHref(site.phonePrimary)}
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-cream text-arbor-900 rounded-full font-semibold hover:bg-white transition shadow-lg w-full sm:w-auto"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        Call {site.phonePrimary}
      </a>
      <a
        href={mailHref(site.email, "Quote request")}
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border-2 border-cream/30 text-cream rounded-full font-semibold hover:bg-cream/10 transition w-full sm:w-auto"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Email diego@titanarbor.com
      </a>
    </div>
  </div>
</section>
