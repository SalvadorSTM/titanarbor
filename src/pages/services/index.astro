---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import CTA from "../../components/CTA.astro";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Services"
  description="All tree care services from Titan Arbor Solutions — removal, trimming, pruning, stump grinding, debris hauling, disease diagnosis, and 24-hour emergency storm response."
>
  <section class="relative text-cream overflow-hidden">
    <img
      src="/images/about.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-arbor-900/85 via-arbor-800/80 to-arbor-900/90" aria-hidden="true"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20 sm:py-28">
      <p class="text-sm uppercase tracking-widest text-arbor-100 mb-3">Our services</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight drop-shadow-lg">
        Tree care, done right
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-arbor-100 max-w-2xl mx-auto">
        Seven services that cover almost any tree on your property — from the routine to the urgent.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <ServiceCard
          title={s.data.title}
          summary={s.data.summary}
          icon={s.data.icon}
          href={`/services/${s.id}/`}
          image={`/images/services/${s.id}.jpg`}
        />
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>
