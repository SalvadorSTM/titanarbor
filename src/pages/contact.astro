---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, telHref, mailHref } from "../lib/site";
import contactHero from "../assets/images/contact.jpg";
---

<BaseLayout
  title="Contact"
  description="Contact Titan Arbor Solutions. Call 478-266-8020, email diego@titanarbor.com. 24-hour emergency tree service across metro Atlanta."
>

  <section class="relative text-cream overflow-hidden">
    <Image
      src={contactHero}
      alt=""
      widths={[640, 1024, 1600]}
      sizes="100vw"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-arbor-900/85 via-arbor-800/80 to-arbor-900/90" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20 sm:py-24">
      <p class="text-sm uppercase tracking-widest text-arbor-100 mb-3">Contact</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight drop-shadow-lg">
        Get a quote, or just ask.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-arbor-100 max-w-2xl mx-auto">
        Fill in the form below for a free quote, or call any time. Diego picks up; if he can't, leave a voicemail and you'll hear back the same day.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-arbor-100/30">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-3 font-semibold">Free quote</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-arbor-900 tracking-tight">Request a free quote</h2>
        <p class="mt-3 text-arbor-900/70 max-w-2xl mx-auto">
          Fill in the basics. Diego will reach out within 24 hours to schedule the on-site assessment.
          For active emergencies, call <a href={telHref(site.phonePrimary)} class="font-semibold underline underline-offset-4 hover:text-arbor-700">{site.phonePrimary}</a> directly.
        </p>
      </div>

      <form
        action="https://formsubmit.co/diego@titanarbor.com"
        method="POST"
        class="bg-white rounded-2xl p-6 md:p-8 border border-arbor-800/15 shadow-sm space-y-5"
      >
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <input type="hidden" name="_subject" value="New quote request — titanarbor.com" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://titanarbor.com/thanks/" />

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-semibold text-arbor-900 mb-1.5">Full name <span class="text-arbor-700">*</span></label>
            <input id="name" name="name" type="text" required autocomplete="name"
              class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-arbor-900 mb-1.5">Phone <span class="text-arbor-700">*</span></label>
            <input id="phone" name="phone" type="tel" required autocomplete="tel"
              class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="email" class="block text-sm font-semibold text-arbor-900 mb-1.5">Email</label>
            <input id="email" name="email" type="email" autocomplete="email"
              class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800" />
          </div>
          <div>
            <label for="address" class="block text-sm font-semibold text-arbor-900 mb-1.5">Property address <span class="text-arbor-700">*</span></label>
            <input id="address" name="address" type="text" required autocomplete="street-address"
              class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="service" class="block text-sm font-semibold text-arbor-900 mb-1.5">Service needed <span class="text-arbor-700">*</span></label>
            <select id="service" name="service" required
              class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800">
              <option value="">Select a service</option>
              <option value="Tree Removal">Tree Removal</option>
              <option value="Tree Trimming">Tree Trimming</option>
              <option value="Pruning">Pruning</option>
              <option value="Stump Grinding">Stump Grinding</option>
              <option value="Debris Hauling">Debris Hauling</option>
              <option value="Disease &amp; Pest Diagnosis">Disease &amp; Pest Diagnosis</option>
              <option value="Emergency Storm Response">Emergency Storm Response</option>
              <option value="Not sure yet">Not sure — need help diagnosing</option>
              <option value="Multiple / Other">Multiple services / Other</option>
            </select>
          </div>
          <div>
            <label for="contact_method" class="block text-sm font-semibold text-arbor-900 mb-1.5">Preferred contact method</label>
            <select id="contact_method" name="contact_method"
              class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800">
              <option value="Phone call">Phone call</option>
              <option value="Text message">Text message</option>
              <option value="Email">Email</option>
            </select>
          </div>
        </div>

        <div>
          <label for="description" class="block text-sm font-semibold text-arbor-900 mb-1.5">Tell us about the tree(s)</label>
          <textarea id="description" name="description" rows="4"
            placeholder="Number of trees, species if you know, what you're hoping for, urgency, anything else useful..."
            class="w-full rounded-xl border border-arbor-800/20 bg-cream/30 px-4 py-3 text-sm text-arbor-900 focus:outline-none focus:ring-2 focus:ring-arbor-800 focus:border-arbor-800 resize-none"></textarea>
        </div>

        <button type="submit"
          class="w-full rounded-full bg-arbor-800 text-cream px-8 py-4 font-semibold text-lg hover:bg-arbor-700 transition shadow-lg">
          Request a free quote
        </button>

        <p class="text-center text-xs text-arbor-900/60">
          We respond within 24 hours. No obligation, no upsells.
        </p>
      </form>
    </div>
  </section>

  <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <p class="text-center text-sm uppercase tracking-widest text-arbor-800 mb-3 font-semibold">Or contact us directly</p>
    </div>
    <div class="max-w-5xl mx-auto grid lg:grid-cols-3 gap-6">

      <a href={telHref(site.phonePrimary)} class="group bg-arbor-800 text-cream rounded-2xl p-8 shadow-lg hover:bg-arbor-700 transition flex flex-col">
        <div class="w-12 h-12 rounded-full bg-cream/15 flex items-center justify-center mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <p class="text-sm uppercase tracking-widest text-arbor-100 mb-2">Primary line</p>
        <p class="text-3xl sm:text-4xl font-bold mb-2 group-hover:underline underline-offset-4">{site.phonePrimary}</p>
        <p class="text-arbor-100/80 text-sm mt-auto">Diego answers. Tap to call.</p>
      </a>

      <a href={telHref(site.phoneBackup)} class="group bg-white border border-arbor-800/15 rounded-2xl p-8 shadow-sm hover:border-arbor-800/30 hover:shadow-lg transition flex flex-col">
        <div class="w-12 h-12 rounded-full bg-arbor-800/10 text-arbor-800 flex items-center justify-center mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-2 font-semibold">Backup line</p>
        <p class="text-3xl sm:text-4xl font-bold text-arbor-900 mb-2 group-hover:underline underline-offset-4">{site.phoneBackup}</p>
        <p class="text-arbor-900/60 text-sm mt-auto">Try this if you can't reach the primary.</p>
      </a>

      <a href={mailHref(site.email, "Tree care inquiry")} class="group bg-white border border-arbor-800/15 rounded-2xl p-8 shadow-sm hover:border-arbor-800/30 hover:shadow-lg transition flex flex-col">
        <div class="w-12 h-12 rounded-full bg-arbor-800/10 text-arbor-800 flex items-center justify-center mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-2 font-semibold">Email</p>
        <p class="text-xl sm:text-2xl font-bold text-arbor-900 mb-2 break-all group-hover:underline underline-offset-4">{site.email}</p>
        <p class="text-arbor-900/60 text-sm mt-auto">Best for photos, multi-tree quotes, non-urgent stuff.</p>
      </a>
    </div>
  </section>

  <section class="bg-white py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-8 text-center sm:text-left">
      <div>
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-2 font-semibold">Hours</p>
        <p class="text-arbor-900 text-lg leading-relaxed">
          Monday – Saturday<br/>
          7:00 AM – 7:00 PM
        </p>
        <p class="text-arbor-800 font-semibold mt-2">24-hour emergency line for storm damage.</p>
      </div>
      <div>
        <p class="text-sm uppercase tracking-widest text-arbor-800 mb-2 font-semibold">Service area</p>
        <p class="text-arbor-900 text-lg leading-relaxed">
          Atlanta and the surrounding metro.<br/>
          Based in Georgia.
        </p>
        <a href="/service-areas/" class="inline-flex items-center gap-1 mt-2 text-arbor-800 font-semibold hover:gap-2 transition-all">
          See full list
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
